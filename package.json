{
  "name": "poo-pbl-grupo-lastmile",
  "version": "1.0.0",
  "description": "Sistema de Logística e Entregas Urbanas (Last Mile) - Projeto Prático Integrador POO",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "dev": "ts-node src/presentation/app.ts",
    "lint": "eslint src tests --ext .ts"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@types/uuid": "^9.0.8",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/tests"],
    "collectCoverageFrom": [
      "src/domain/**/*.ts",
      "src/application/**/*.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}
